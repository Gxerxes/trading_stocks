# Tushare API 配置
# 从 https://tushare.pro 获取token
TUSHARE_TOKEN=your_tushare_token_here

# 分析模式配置（重要！）
# local - 使用本地规则分析（推荐，不需要 OpenAI API Key）
# api   - 调用 OpenAI API 分析（需要 API Key）
ANALYSIS_MODE=local

# 策略配置（支持单选或多选，逗号分隔）
# 可选：trend_momentum_volume, api, wyckoff
# 兼容别名：local -> trend_momentum_volume
# 示例：
# STRATEGIES=wyckoff
# STRATEGIES=trend_momentum_volume,wyckoff
STRATEGIES=trend_momentum_volume

# OpenAI API 配置（仅 ANALYSIS_MODE=api 时需要）
OPENAI_API_KEY=your_openai_api_key_here
# 如果使用国内代理或自部署，设置此项
# OPENAI_API_BASE=https://api.openai.com/v1

# 模型选择（仅 ANALYSIS_MODE=api 时使用）
OPENAI_MODEL=gpt-4
# 也可以选择其他模型
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_MODEL=gpt-4-turbo-preview

# LLM 参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# 日志级别
LOG_LEVEL=INFO

# API 超时设置（秒）
API_TIMEOUT=30
RETRY_ATTEMPTS=3

STRATEGIES=local,wyckoff
